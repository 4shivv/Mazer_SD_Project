PORT=4000
MONGO_URL=mongodb://localhost:27017/mazerai
JWT_SECRET=change-me-local-dev-secret

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

CHROMA_HOST=http://localhost:8000
CHROMA_COLLECTION=ew_training_materials
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

RETENTION_SWEEP_INTERVAL_MS=60000
ADMIN_WIPE_CONFIRMATION_CODE=MAZER_CONFIRM_WIPE

# Optional: only needed if you want admin model reset to also remove local
# filesystem model/cache directories in addition to deleting models via Ollama.
# OLLAMA_MODEL_STORAGE_PATHS=/absolute/path/to/models
# OLLAMA_CACHE_PATHS=/absolute/path/to/cache1,/absolute/path/to/cache2

# Optional: only needed if you expose an internal Chroma wipe endpoint.
# CHROMA_WIPE_ENDPOINT=
